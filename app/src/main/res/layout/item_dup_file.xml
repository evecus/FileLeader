<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="48dp"
    android:paddingEnd="16dp"
    android:paddingVertical="10dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_item_selectable">

    <CheckBox
        android:id="@+id/cbFile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/teal_400"
        android:layout_marginEnd="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/grey_900"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="middle" />

            <!-- "保留" badge shown on keep-candidate -->
            <TextView
                android:id="@+id/tvKeepBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保留"
                android:textSize="10sp"
                android:textColor="@color/keep_badge_text"
                android:background="@drawable/bg_keep_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFilePath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/grey_400"
            android:singleLine="true"
            android:ellipsize="start"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvFileDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/grey_400"
            android:layout_marginTop="1dp" />
    </LinearLayout>

</LinearLayout>
